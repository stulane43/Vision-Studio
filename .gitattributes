# Normalize all text files to LF in the repo so the Docker image builds cleanly
# on Linux (CRLF in a Dockerfile or shell script breaks the build).
* text=auto eol=lf

# Treat binary assets as binary (no EOL conversion).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
