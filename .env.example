# ─────────────────────────────────────────────────────────────
# Vision Studio — environment configuration
# Copy this file to ".env.local" and fill in your values.
# NEVER commit .env.local (it is gitignored). SECURITY-12.
# ─────────────────────────────────────────────────────────────

# Default AI provider for new accounts: "anthropic", "openai", or "mock".
# "mock" runs the entire app deterministically WITHOUT any API key.
# (Each account can also choose its own provider in Settings.)
AIDLC_PROVIDER=mock

# Optional shared API keys. If set, they act as a fallback for any account that
# hasn't entered its own key in Settings. Leave blank to require per-account keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default model used for generation (Anthropic). Examples:
# claude-sonnet-4-6 (fast/cost-effective), claude-opus-4-8 (deepest).
AIDLC_MODEL=claude-sonnet-4-6

# Root directory for ALL persisted data (accounts, settings, projects).
# Locally this defaults to the project root. In a container set this to /data
# and mount a single volume there.
# AIDLC_DATA_DIR=/data

# Where projects are persisted (defaults to <AIDLC_DATA_DIR>/projects).
# AIDLC_PROJECTS_DIR=projects

# Set to "true" ONLY when the app is served over HTTPS (e.g. behind a reverse
# proxy). Enables Secure cookies + HSTS. Leave false for plain-HTTP LAN access,
# otherwise the login cookie won't be sent and sign-in will fail.
AIDLC_HTTPS=false
